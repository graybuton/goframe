package main

import gf "github.com/graybuton/goframe/pkg/goframe"

type DashboardAppProps struct{}

func DashboardApp(props DashboardAppProps) gf.Node {
	issues, dispatchIssues := gf.UseReducer(resetDemoIssues(), reduceIssues)
	query, setQuery := gf.UseState("")
	statusFilter, setStatusFilter := gf.UseState(StatusAll)
	priorityFilter, setPriorityFilter := gf.UseState(PriorityAll)
	sortMode, setSortMode := gf.UseState(SortByUpdated)

	filters := FilterState{
		Query:    query,
		Status:   statusFilter,
		Priority: priorityFilter,
		Sort:     sortMode,
	}
	visible := visibleIssues(issues, filters)
	metrics := dashboardMetrics(issues, len(visible))

	gf.UseEffect(func() gf.Cleanup {
		setDocumentTitle("GoFrame Dashboard · " + gf.ToString(len(visible)) + " visible")
		return nil
	}, gf.Deps(len(visible)))

	reset := func() {
		dispatchIssues(IssueAction{Kind: IssueActionReset})
		setQuery("")
		setStatusFilter(StatusAll)
		setPriorityFilter(PriorityAll)
		setSortMode(SortByUpdated)
	}

	toggleIssue := func(id int) {
		dispatchIssues(IssueAction{Kind: IssueActionToggle, ID: id})
	}

	simulateUpdate := func() {
		dispatchIssues(IssueAction{Kind: IssueActionSimulate})
	}

	return (
		<DashboardShell>
			<MetricsGrid Metrics={metrics} />

			<Card Title="Filters" TestID="filters-card">
				<FilterBar
					Filters={filters}
					OnQuery={setQuery}
					OnStatus={setStatusFilter}
					OnPriority={setPriorityFilter}
					OnSort={setSortMode}
					OnReset={reset}
					OnSimulate={simulateUpdate}
				/>
			</Card>

			<IssueWorkspace
				Items={visible}
				AllItems={issues}
				Query={query}
				OnToggle={toggleIssue}
			/>
		</DashboardShell>
	)
}

func App() gf.Node {
	return (
		<>
			<Header
				Title="Operations Dashboard"
				Subtitle="A dashboard-sized GOX pressure test with filters, keyed rows, and derived views."
			/>
			<DashboardApp />
		</>
	)
}
