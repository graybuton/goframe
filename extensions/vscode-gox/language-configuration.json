{
  "comments": {
    "lineComment": "//",
    "blockComment": [
      "/*",
      "*/"
    ]
  },
  "brackets": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "<",
      ">"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{",
      "close": "}"
    },
    {
      "open": "[",
      "close": "]"
    },
    {
      "open": "(",
      "close": ")"
    },
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "`",
      "close": "`",
      "notIn": [
        "string",
        "comment"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ],
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ],
    [
      "`",
      "`"
    ],
    [
      "<",
      ">"
    ]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*(\\{[^}\"'`]*|\\([^\\)\"'`]*|\\[[^\\]\"'`]*|<([A-Za-z][A-Za-z0-9:_-]*)\\b[^>]*>)\\s*$",
    "decreaseIndentPattern": "^\\s*(\\}|\\)|\\]|</[A-Za-z][A-Za-z0-9:_-]*>|</>)"
  }
}
